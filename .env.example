GEMINI_API_KEY=
TARGET_LANGUAGE=bn
INPUT_DIR=input
OUTPUT_DIR=output
PROCESSING_DIR=processing
FAILED_DIR=failed
FFMPEG_BIN_DIR=C:\ffmpeg\bin
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=BZgkqPqms7Kj9ulSkVzn
ELEVENLABS_MODEL_ID=eleven_v3

# Vocal separation settings
# Options: htdemucs (fast, default), htdemucs_ft (higher precision, slower)
DEMUCS_MODEL=htdemucs
# Set to 2 or 4 to run multiple random shifts for extra separation precision (much slower)
DEMUCS_SHIFTS=0

# Gemini TTS Settings
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# Available female voices: Achernar, Salufat
GEMINI_TTS_FEMALE_VOICE=Achernar
# Available male voices: Fenrir, Schedar
GEMINI_TTS_MALE_VOICE=Fenrir
